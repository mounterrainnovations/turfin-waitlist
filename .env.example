# ZeptoMail (Zoho)
ZEPTO_MAIL_TOKEN=your-zeptomail-token
ZEPTO_TEMPLATE_KEY_WELCOME=your-template-key
ZEPTO_TEMPLATE_KEY_DAILY_SUMMARY=your-template-key
